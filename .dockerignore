# Version-control artefacts
.git
.gitignore

# Docs
*.md

# Vercel-only entry point (not needed in the Docker image)
api/
vercel.json

# Flutter is an independent mobile app service – not part of the Docker deployment
flutter/

# Python byte-code and caches
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd

# Local environment files
.env
.env.*
